digraph rider {
  graph [rankdir=TB, bgcolor="white", fontname="Helvetica", nodesep=0.32, ranksep=0.4, pad=0.28, ];
  node  [fontname="Helvetica", fontsize=12, margin="0.17,0.10", penwidth=1.3];
  edge  [fontname="Helvetica", fontsize=10, color="#64748b", arrowsize=0.75, penwidth=1.1];
  "ri_login" [label="Rider login", shape=oval, style="filled", fillcolor="#1d4ed8", color="#1e3a8a", fontcolor="white", fontsize=12, penwidth=1.6];
  "ri_first" [label="First-time?
set password", shape=box, style="rounded,filled", fillcolor="#ECFDF5", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_duty" [label="Go on-duty
availability toggle", shape=box, style="rounded,filled", fillcolor="#ECFDF5", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_notif" [label="Receive task_assigned
notification", shape=box, style="rounded,filled", fillcolor="#ECFDF5", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_tasks" [label="Task list / batch overview
ordered stops", shape=box, style="rounded,filled", fillcolor="#ECFDF5", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_detail" [label="Task detail
order · customer · notes", shape=box, style="rounded,filled", fillcolor="#ECFDF5", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_nav" [label="Navigate (map)
call customer", shape=box, style="rounded,filled", fillcolor="#ECFDF5", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_pick" [label="Pick up
assigned → picked_up → in_transit", shape=box, style="rounded,filled", fillcolor="#ECFDF5", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_try" [label="At customer:
deliver?", shape=diamond, style="filled", fillcolor="#FEF3C7", color="#d97706", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_pod" [label="Proof of delivery (RF-09)
enter OTP + recipient
photo / signature · open-box", shape=box, style="rounded,filled", fillcolor="white", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_deliv" [label="status = delivered", shape=box, style="filled", fillcolor="#D1FAE5", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_fail" [label="Failed delivery (RF-10)
unavailable · wrong address
refused · other", shape=box, style="rounded,filled", fillcolor="#FEE2E2", color="#dc2626", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_earn" [label="Earnings & history
per-delivery + incentives", shape=box, style="rounded,filled", fillcolor="#ECFDF5", color="#059669", fontcolor="#0f172a", fontsize=12, penwidth=1.3];
  "ri_login" -> "ri_first" [style=solid, color="#64748b"];
  "ri_first" -> "ri_duty" [style=solid, color="#64748b"];
  "ri_duty" -> "ri_notif" [style=solid, color="#64748b"];
  "ri_notif" -> "ri_tasks" [style=solid, color="#64748b"];
  "ri_tasks" -> "ri_detail" [style=solid, color="#64748b"];
  "ri_detail" -> "ri_nav" [style=solid, color="#64748b"];
  "ri_nav" -> "ri_pick" [style=solid, color="#64748b"];
  "ri_pick" -> "ri_try" [style=solid, color="#64748b"];
  "ri_try" -> "ri_pod" [style=solid, color="#059669", label="yes", fontcolor="#059669"];
  "ri_try" -> "ri_fail" [style=solid, color="#dc2626", label="no", fontcolor="#dc2626"];
  "ri_pod" -> "ri_deliv" [style=solid, color="#64748b"];
  "ri_deliv" -> "ri_earn" [style=dashed, color="#64748b", label="end of shift"];
  "ri_fail" -> "ri_tasks" [style=dashed, color="#dc2626", label="next task"];
}
