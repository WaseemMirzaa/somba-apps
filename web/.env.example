# Somba&Teka web — environment template. Copy to `.env.local`.
# Base URL of the NestJS API (REST auth). No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Socket.IO endpoint (usually same origin as the API).
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Existing prototype market toggle (france | drc)
NEXT_PUBLIC_MARKET_PROFILE=france
