{
  "name": "somba-apps",
  "version": "0.1.0",
  "private": true,
  "description": "Somba & Teka — France & global marketplace prototype (mocked mode)",
  "scripts": {
    "dev:web": "npm run dev --prefix web",
    "dev:api": "npm run start:dev --prefix api",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build:web": "npm run build --prefix web",
    "build:api": "npm run build --prefix api",
    "dev:mobile": "cd mobile && flutter run",
    "dev:rider": "cd rider-app && flutter run"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
