# ---- Runtime ----
NODE_ENV=development
PORT=3001

# ---- MySQL ----
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=somba
DB_DATABASE=somba
# Auto-create/sync tables from entities (dev only; disable in prod + use migrations)
DB_SYNCHRONIZE=true

# ---- Auth ----
JWT_SECRET=change-me-in-production
JWT_EXPIRES=7d

# ---- File uploads ----
# ONE storage base directory. Every upload context is just a different sub-path
# under this same base (products, seller-kyc, promotions, disputes, ...).
UPLOAD_DIR=./uploads
# Public URL prefix the API serves stored files under.
UPLOAD_PUBLIC_PREFIX=/uploads

# ---- Seed ----
# Default password given to every seeded account (admin + sellers).
SEED_PASSWORD=password123
