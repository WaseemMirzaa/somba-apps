# ─────────────────────────────────────────────────────────────
# Somba&Teka API — environment template
# Copy to `.env` and fill real secrets. `.env` is gitignored.
# Generate secrets with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────

# HTTP + realtime port
PORT=3001

# Comma-separated list of allowed web/app origins (CORS + socket handshake)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Auth (JWT) ────────────────────────────────────────────────
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-another-openssl-rand-hex-32
JWT_REFRESH_TTL=30d

# ── Field encryption (AES-256-GCM) ────────────────────────────
# MUST be 64 hex chars (= 32 bytes). Encrypts email/phone/address at rest.
DATA_ENCRYPTION_KEY=replace-with-64-hex-chars

# ── Database ──────────────────────────────────────────────────
# DB_TYPE = sqlite (local, zero-setup) | mysql (production, per CONFIG.md)
DB_TYPE=sqlite
DB_SQLITE_FILE=somba.dev.sqlite
DB_SYNCHRONIZE=true

# MySQL settings (used only when DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=somba
